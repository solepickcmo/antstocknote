generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm]
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  nickname               String    // auth.users 연동 트리거 사용
  public_profile_enabled Boolean   @default(false)
  community_joined_at    DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now())
  deleted_at             DateTime?

  trades Trade[]
  tags     Tag[]

  @@index([email])
  @@map("users")
}


model Trade {
  id           Int       @id @default(autoincrement())
  user_id      String
  ticker       String
  name         String
  type         String    // "buy" | "sell"
  price        Decimal   @db.Decimal(18, 2)
  quantity     Decimal   @db.Decimal(18, 8)
  fee          Decimal   @db.Decimal(18, 2) @default(0)
  pnl          Decimal?  @db.Decimal(18, 2)
  traded_at    DateTime
  strategy_tag String?
  emotion_tag  String?
  memo         String?
  is_open      Boolean   @default(true)
  is_public    Boolean   @default(false)
  created_at   DateTime  @default(now())
  deleted_at   DateTime?

  user    User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  note    Note?

  @@index([user_id])
  @@index([traded_at(sort: Desc)])
  @@index([ticker])
  @@index([strategy_tag])
  @@index([is_open])
  @@index([is_public])
  @@map("trades")
}

model Note {
  id           Int      @id @default(autoincrement())
  trade_id     Int      @unique
  mistake_type String?
  content      String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  deleted_at   DateTime?

  trade Trade @relation(fields: [trade_id], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Tag {
  id      Int     @id @default(autoincrement())
  user_id String
  name    String
  type    String  // "strategy" | "emotion"

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, name, type])
  @@map("tags")
}

model StockMaster {
  id     Int    @id @default(autoincrement())
  ticker String @unique @db.VarChar(20)
  name   String @db.VarChar(100)
  market String @db.VarChar(20)

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("stock_master")
}

model Subscription {
  user_id    String    @id
  tier       String    // "free" | "premium"
  status     String    // "active" | "pending" | "expired" | "canceled"
  expires_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  @@map("subscriptions")
}

model InvestmentPrinciple {
  id         String   @id @default(uuid())
  user_id    String
  order_num  Int            // 원칙 순서 (1~5)
  content    String         // 원칙 내용
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // user_id + order_num 조합이 유일해야 함 (동일 순번 중복 불가)
  @@unique([user_id, order_num])
  @@index([user_id])
  @@map("investment_principles")
}

model StockAnalysis {
  id            String   @id @default(uuid())
  user_id       String
  ticker        String?  // 보유 종목 연동 (nullable: 비보유 종목도 기록 가능)
  stock_name    String?
  title         String
  content       String   // 분석 본문 (plain text or markdown)
  analysis_date DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // user_id + ticker 조합으로 종목별 분석 검색 최적화
  @@index([user_id, ticker])
  @@index([user_id, analysis_date(sort: Desc)])
  @@map("stock_analyses")
}
